{
    "job_name": "job{{ job_id }}",
    "source": "workflow",
    "endpoint": "http://data-check-in.default.svc.cluster.local:8296/data/getDataFromFile",
    "input_data": [
        {
            "name": "file",
            "value": "job{{ job_id }}.source"
        },
        {
            "name": "metadata",
            "value": "job{{ job_id }}.metadata"
        }
    ],
    "method": "post",
    "content-type": "application/json",
    "destination_type": "memory",
    "response_dataset_field_path": "data.file_url",
    "response_metadata_field_path": "none"
}