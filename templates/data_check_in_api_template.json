{
    "job_name": "job{{ job_id }}",
    "source": "job",
    "endpoint": "http://data-check-in.default.svc.cluster.local:8296/data/getDataFromAPI",
    "input_data": [
        {
            "name": "api_url",
            "value": "{{ api_url }}"
        },
        {
            "name": "method",
            "value": "{{ method }}"
        },
        {
            "name": "headers",
            "value": "{{ headers }}"
        },
        {
            "name": "query_params",
            "value": "{{ query_params }}"
        },
        {
            "name": "body",
            "value": "{{ body }}"
        },
        {
            "name": "filename",
            "value": "{{ filename }}"
        }     
    ],
    "method": "post",
    "content-type": "application/json",
    "destination_type": "memory",
    "response_dataset_field_path": "data.file_url",
    "response_metadata_field_path": "none"
}